# ── Supabase ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# NEVER put this in the app — Edge Functions only
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── Stripe ───────────────────────────────────────────────────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY

# NEVER put these in the app — Edge Functions only
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# ── RevenueCat ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_YOUR_KEY
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_YOUR_KEY

# ── Google Maps ──────────────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY

# ── Platform ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_PLATFORM_COMMISSION=0.12
